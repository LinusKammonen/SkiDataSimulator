<Window x:Class="SkiDataSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SkiDataSimulator"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Rectangle HorizontalAlignment="Center" Height="436" Stroke="Black" VerticalAlignment="Center" Width="800"/>
        <Grid x:Name="Rides" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0" d:IsHidden="True">
            <Rectangle HorizontalAlignment="Center" Height="435" Stroke="Black" VerticalAlignment="Center" Width="799"/>
            <TextBlock HorizontalAlignment="Left" Margin="234,135,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="Välj destination:"/></TextBlock>
