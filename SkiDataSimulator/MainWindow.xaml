        <Grid x:Name="Register" HorizontalAlignment="Center" Margin="0,52,0,0" VerticalAlignment="Top" d:IsHidden="True">
            <Rectangle HorizontalAlignment="Center" Height="382" Stroke="Black" VerticalAlignment="Center" Width="800"/>
            <TextBlock HorizontalAlignment="Left" Margin="360,54,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="138"><Run Language="sv-se" Text="Registrera skidåkare"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="256,82,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="förnamn:"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="256,108,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="efternamn"/><Run Text=":"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="256,136,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="email:"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="256,164,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Text="användarnamn"/><Run Language="sv-se" Text=":"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="256,190,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="bild (valfritt):"/></TextBlock>
            <TextBox x:Name="txtFirstName" HorizontalAlignment="Left" Margin="344,82,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="144"/>
            <TextBox x:Name="txtLastName" HorizontalAlignment="Left" Margin="344,106,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="144"/>
            <TextBox x:Name="txtEmail" HorizontalAlignment="Left" Margin="344,136,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="144"/>
            <TextBox x:Name="txtUsername" HorizontalAlignment="Left" Margin="344,164,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="144"/>
            <TextBox x:Name="txtImageUrl" HorizontalAlignment="Left" Margin="344,190,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="144"/>
            <Button x:Name="btnRegister" Content="Registrera" HorizontalAlignment="Left" Margin="368,220,0,0" VerticalAlignment="Top" Width="120" Click="btnRegister_Click"/>
        </Grid>
        <Button Content="Sökfunktion" HorizontalAlignment="Left" Margin="534,0,0,0" VerticalAlignment="Top" Width="134" Height="52" Click="Button_Click"/>
    </Grid>

</Window>
