            <Rectangle HorizontalAlignment="Center" Height="434" Stroke="Black" VerticalAlignment="Center" Width="800"/>
            <TextBlock HorizontalAlignment="Left" Margin="353,119,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="138" FontWeight="Bold"><Run Language="sv-se" Text="Registrera skidåkare"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="241,152,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="förnamn:"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="241,178,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="efternamn"/><Run Text=":"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="241,206,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="email:"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="241,234,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Text="användarnamn"/><Run Language="sv-se" Text=":"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="241,260,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="bild (valfritt):"/></TextBlock>
            <TextBox x:Name="txtFirstName" HorizontalAlignment="Left" Margin="329,152,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="162"/>
            <TextBox x:Name="txtLastName" HorizontalAlignment="Left" Margin="329,176,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="162"/>
            <TextBox x:Name="txtEmail" HorizontalAlignment="Left" Margin="329,206,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="162"/>
            <TextBox x:Name="txtUsername" HorizontalAlignment="Left" Margin="329,234,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="162"/>
            <TextBox x:Name="txtImageUrl" HorizontalAlignment="Left" Margin="329,262,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="162"/>
            <Button x:Name="btnRegister" Content="Registrera" HorizontalAlignment="Left" Margin="371,290,0,0" VerticalAlignment="Top" Width="120" Click="btnRegister_Click"/>
        </Grid>
        <Grid x:Name="Delete" HorizontalAlignment="Center" VerticalAlignment="Center" d:IsHidden="True">
            <Rectangle HorizontalAlignment="Center" Height="432" Stroke="Black" VerticalAlignment="Center" Width="800"/>
            <ComboBox x:Name="cbDeleteResorts" HorizontalAlignment="Center" Margin="0,123,0,0" VerticalAlignment="Top" Width="188"/>
            <ComboBox x:Name="cbDeleteLifts" HorizontalAlignment="Center" Margin="0,266,0,0" VerticalAlignment="Top" Width="188"/>
            <TextBlock HorizontalAlignment="Left" Margin="373,240,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="79"><Run Text="Välj lift"/><Run Language="sv-se" Text=":"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="368,94,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="80"><Run Text="Välj "/><Run Text="resort"/><Run Language="sv-se" Text=":"/></TextBlock>
            <Button x:Name="btnDeleteResort" Content="Ta bort resort"  HorizontalAlignment="Center" Margin="0,158,0,0" VerticalAlignment="Top" Background="Red" Click="btnDeleteResort_Click"/>
            <Button x:Name="btnDeleteLift" Content="Ta bort lift" HorizontalAlignment="Center" Margin="0,301,0,0" VerticalAlignment="Top" Width="74" Background="#FFF13737" Click="btnDeleteLift_Click"/>
