            <TextBlock HorizontalAlignment="Left" Margin="382,151,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="Efternamn:"/></TextBlock>
            <Label Content="Profil" HorizontalAlignment="Left" Margin="373,75,0,0" VerticalAlignment="Top"/>
            <Label Content="Säsongsdata" HorizontalAlignment="Left" Margin="373,177,0,0" VerticalAlignment="Top"/>
            <Label Content="Övriga data" HorizontalAlignment="Left" Margin="375,293,0,0" VerticalAlignment="Top"/>
            <TextBlock HorizontalAlignment="Left" Margin="382,109,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Text="Användarnamn"/><Run Language="sv-se" Text=":"/></TextBlock>
            <Rectangle HorizontalAlignment="Left" Height="76" Margin="373,101,0,0" Stroke="Gray" VerticalAlignment="Top" Width="228"/>
            <TextBlock HorizontalAlignment="Left" Margin="378,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center"><Run Language="sv-se" Text="Säsong:"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="377,249,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="Totala åk:"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="377,268,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="Antal dagar: "/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="377,229,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="liftkort (t.o.m)"/></TextBlock>
            <Rectangle HorizontalAlignment="Left" Height="86" Margin="373,207,0,0" Stroke="Gray" VerticalAlignment="Top" Width="373"/>
            <TextBlock HorizontalAlignment="Left" Margin="378,324,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="total fallhöjd (m):"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="377,345,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Text="Antal besökta länder"/><Run Language="sv-se" Text=":"/></TextBlock>
            <Rectangle HorizontalAlignment="Left" Height="90" Margin="373,319,0,0" Stroke="Gray" VerticalAlignment="Top" Width="373"/>
            <TextBlock x:Name="txtUser" HorizontalAlignment="Left" Margin="470,111,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="124"/>
            <TextBlock x:Name="txtFirst" HorizontalAlignment="Left" Margin="470,132,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="124"/>
            <TextBlock x:Name="txtLast" HorizontalAlignment="Left" Margin="470,153,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="124"/>
            <TextBlock x:Name="txtSeason" HorizontalAlignment="Left" Margin="470,213,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="223" Height="15"/>
            <TextBlock x:Name="txtEndDate" HorizontalAlignment="Left" Margin="470,233,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="223" Height="15"/>
            <TextBlock x:Name="txtRuns" HorizontalAlignment="Left" Margin="470,252,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="223" Height="15"/>
            <TextBlock x:Name="txtDays" HorizontalAlignment="Left" Margin="470,269,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="223" Height="15"/>
            <TextBlock x:Name="txtDrop" HorizontalAlignment="Left" Margin="476,327,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="118"/>
            <TextBlock x:Name="txtCountries" HorizontalAlignment="Left" Margin="494,348,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="100"/>
