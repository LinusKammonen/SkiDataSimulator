            <Label Content="Övriga data" HorizontalAlignment="Left" Margin="375,293,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
            <TextBlock HorizontalAlignment="Left" Margin="382,109,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Text="Användarnamn"/><Run Language="sv-se" Text=":"/></TextBlock>
            <Rectangle HorizontalAlignment="Left" Height="76" Margin="373,101,0,0" Stroke="Gray" VerticalAlignment="Top" Width="228"/>
            <TextBlock HorizontalAlignment="Left" Margin="378,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center"><Run Language="sv-se" Text="Säsong:"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="377,249,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="Totala åk:"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="377,268,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="Antal dagar: "/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="377,229,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="liftkort (t.o.m)"/></TextBlock>
            <Rectangle HorizontalAlignment="Left" Height="86" Margin="373,207,0,0" Stroke="Gray" VerticalAlignment="Top" Width="373"/>
            <TextBlock HorizontalAlignment="Left" Margin="378,324,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="total fallhöjd (m):"/></TextBlock>
