            <Button x:Name="btnRegisterRide" Content="Registrera åk" HorizontalAlignment="Left" Margin="383,278,0,0" VerticalAlignment="Top" Width="122" Click="btnRegisterRide_Click"/>
            <TextBlock HorizontalAlignment="Left" Margin="234,0,0,0" TextWrapping="Wrap" VerticalAlignment="Center"><Run Text="Välj "/><Run Language="sv-se" Text="lift:"/></TextBlock>
            <ComboBox x:Name="cbLifts" HorizontalAlignment="Left" Margin="333,209,0,0" VerticalAlignment="Top" Width="172"/>
            <TextBlock HorizontalAlignment="Left" Margin="373,96,0,0" TextWrapping="Wrap" VerticalAlignment="Top" FontWeight="Bold"><Run Language="sv-se" Text="Registrera ett åk"/></TextBlock>
        </Grid>
        <Grid x:Name="Liftkort" HorizontalAlignment="Left" VerticalAlignment="Top" d:IsHidden="True">
            <TextBlock HorizontalAlignment="Left" Margin="290,64,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Text="Köp liftkort" FontWeight="Bold"/>
