            <TextBox x:Name="txtCardNumber" HorizontalAlignment="Left" Margin="408,127,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
            <ComboBox x:Name="cbPasses" HorizontalAlignment="Left" Margin="444,211,0,0" VerticalAlignment="Top" Width="148"/>
        </Grid>
        <Button Content="Registrering" HorizontalAlignment="Left" VerticalAlignment="Top" Width="135" Height="52" Margin="137,0,0,0" Click="Button_Click_1"/>
        <Button Content="Sökfunktion" HorizontalAlignment="Left" Margin="272,0,0,0" VerticalAlignment="Top" Width="134" Height="52" Click="Button_Click"/>
        <Grid x:Name="Searchfunction" HorizontalAlignment="Center" VerticalAlignment="Center" Height="434" d:IsHidden="True">
            <Rectangle HorizontalAlignment="Center" Height="434" Stroke="Black" VerticalAlignment="Center" Width="800"/>
            <StackPanel Orientation="Vertical" Margin="-811,13,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <TextBox x:Name="txtSearchSkier" HorizontalAlignment="Left" Margin="17,104,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="165"/>
            <TextBlock HorizontalAlignment="Left" Margin="17,77,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="165" FontWeight="Bold"><Run Language="sv-se" Text="Sök efter skidåkare:"/></TextBlock>
