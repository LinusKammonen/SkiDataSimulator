<Window x:Class="SkiDataSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SkiDataSimulator"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="5" VerticalAlignment="Top" HorizontalAlignment="Left">
            <Button x:Name="btnSimulateSeason" Content="Simulera säsong" Width="150" Margin="5" Click="OnButtonSimulateSeasonClick"/>
            <Button x:Name="btnSimulateDay" Content="Simulera dag" Width="150" Margin="5" Click="OnButtonSimulateDayClick"/>
        </StackPanel>
        <TextBlock HorizontalAlignment="Left" Margin="637,19,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="138"><Run Language="sv-se" Text="Registrera skidåkare"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="533,49,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="förnamn:"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="533,76,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="efternamn"/><Run Text=":"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="533,104,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="email:"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="533,131,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Text="användarnamn"/><Run Language="sv-se" Text=":"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="533,158,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="sv-se" Text="bild (valfritt):"/></TextBlock>
        <TextBox x:Name="txtFirstName" HorizontalAlignment="Left" Margin="637,49,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txtLastName" HorizontalAlignment="Left" Margin="637,74,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txtEmail" HorizontalAlignment="Left" Margin="637,103,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txtUsername" HorizontalAlignment="Left" Margin="637,131,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txtImageUrl" HorizontalAlignment="Left" Margin="637,158,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <Button x:Name="btnRegister" Content="Registrera" HorizontalAlignment="Left" Margin="637,187,0,0" VerticalAlignment="Top" Width="120" Click="btnRegister_Click"/>


    </Grid>
</Window>
