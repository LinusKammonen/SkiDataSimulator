        <Button x:Name="btnLiftkort" Content="Liftkort" HorizontalAlignment="Left" Margin="406,0,0,0" VerticalAlignment="Top" Height="52 " Width="132" Click="btnLiftkort_Click"/>
        <Button x:Name="btnDelete" Content="Radera" HorizontalAlignment="Left" Margin="672,0,0,0" VerticalAlignment="Top" Height="52" Width="128" Click="btnDelete_Click"/>
        <Button x:Name="btnRides" Content="Registrera åk" HorizontalAlignment="Left" Margin="538,0,0,0" VerticalAlignment="Top" Height="52" Width="134" Click="btnRides_Click"/>
        <Button x:Name="btnSimulator" Content="Simulator" HorizontalAlignment="Left" VerticalAlignment="Top" Height="52" Width="137" Click="btnSimulator_Click"/>
        <Grid x:Name="Simulator" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Rectangle HorizontalAlignment="Center" Height="436" Stroke="Black" VerticalAlignment="Center" Width="800"/>
            <Button x:Name="btnSimulateDay" Content="Simulera dag" Click="OnButtonSimulateDayClick" Margin="126,74,494,298"/>
            <Button x:Name="btnSimulateSeason" Content ="Simulera säsong" Margin="509,74,111,297" Click="OnButtonSimulateSeasonClick" RenderTransformOrigin="0.313,0.846"/>
            <ListBox x:Name="lstDayResults" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="21,176,400,41"/>
            <ListBox x:Name="lstSeasonResults" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="415,176,20,41"/>
            <TextBlock HorizontalAlignment="Left" Margin="137,150,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="158"><Run Language="sv-se" Text="Sammanställning av dag:"/></TextBlock>
            <TextBlock HorizontalAlignment="Left" Margin="523,150,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="158"><Run Text="Sammanställning av "/><Run Language="sv-se" Text="säsong:"/></TextBlock>
